# Agnes Finance Research - environment variables.
# Copy this file to .env and fill in your keys. Never commit your real .env.

# Required for live synthesis, the hero image, and the recap video.
# Without it the app still runs and serves grounded digests using the
# deterministic offline synthesis and locally drawn posters.
# Get a key at https://apihub.agnes-ai.com
AGNES_API_KEY=

# Optional. Improves web search and Reddit results when set.
# Falls back to keyless sources when empty.
BRAVE_API_KEY=
